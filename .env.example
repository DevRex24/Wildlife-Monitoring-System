# Wildlife Monitoring System - Environment Variables
# Copy this file to .env and fill in your values

# Email Configuration (Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-16-char-app-password
OFFICER_EMAIL=officer-email@gmail.com

# Detection Settings
CONFIDENCE_THRESHOLD=0.5
ALERT_COOLDOWN=10

# Flask Settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
DEBUG_MODE=False
